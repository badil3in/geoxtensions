    <div class="container py-5">
        <h1 class="mt-5">Module</h1>
        <div class="row px-4 py-5 row-cols-1 row-cols-md-3 g-4">
            {% for module in modules %}
                <div class="col">
                    <div class="card">
                        <img src="#" class="card-img-top bg-magic-secondary" alt="#">
                        <div class="card-body">
                            <h5 class="card-title mt-3">{{ module.name }}</h5>
                            <div class="underline-highlight"></div>
                            <p class="card-text mt-3">{{ module.summary }}</p>
                            <!-- <ul>
                                {% for item in module.description %}
                                    <li>
                                        {{ item.text }}
                                        {% if item.subtext %}
                                            <ul>
                                                {% for sub in item.subtext %}
                                                    <li> {{ sub }} </li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                            </ul> -->
                        </div>
                        <button class="btn btn-magic-primary m-3">
                            Download 
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download" viewBox="0 0 16 16">
                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
                            </svg>
                        </button>
                    </div>  
                </div>
            {% endfor %}
        </div>
    </div>
</div>