{% if isSearch %}

    <div class="container mt-5 my-auto px-4 py-5">
        <h1 class="display-4 mt-md-5">Suchergebnisse ( {{ modules.length }} )</h1>
    </div>

{% else %}

{% include "carousel.njk" %}

{% endif %}

{% if modules.length == 0 %}
    <div class="container px-4">
        <p class="fs-4">
            Keine Module mit diesem Suchbegriff gefunden
        </p>
    </div>
{% else %}
    <div class="container-fluid py-5">
        <div class="container">
            <div class=""></div>
            <h1 class="display-5 mt-md-5">Module</h1>
            <div class="container">
                {% for module in modules %}
                    <hr class="my-md-5 my-3 text-magic-secondary">
                    <div class="row">
                        <div class="col-md-7 order-md-1 py-3 py-md-5">
                            <h2 class="mt-lg-5 fw-light lh-1">{{ module.name }}</h2>    
                            <div class="underline-highlight mb-3"></div>
                            <div class="fs-6 fw-light lh-sm px-1 version">
                                v{{ module.version}}
                            </div>
                            <p class="card-text mt-3">{{ module.summary }}</p>
                            <div class="justify-content-center justify-content-md-start module-buttons row my-2">
                                <div class="col-5 col-sm-5">
                                    <button type="button" class="btn btn-magic-primary fw-light h-100 w-100" data-bs-toggle="modal" data-bs-target="#moduleModal{{ module.id }}">
                                        Details
                                    </button>
                                </div>
                                <div class="col-5 col-sm-5">
                                    <button class="btn btn-magic-primary fw-light h-100 w-100">
                                        <span class="align-middle">Download</span>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download mx-1" viewBox="0 0 16 16">
                                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                                                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
                                            </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 d-flex my-2 order-md-2">
                            <svg aria-label="Placeholder: 400x400" class="bd-placeholder-img bd-placeholder-img-lg img-fluid align-items-center justify-content-center my-auto mx-auto" height="400" preserveAspectRatio="xMidYMid slice" role="img" width="400" xmlns="http://www.w3.org/2000/svg">
                                <title>Placeholder</title>
                                <rect width="100%" height="100%" fill="var(--bs-magic-tertiary)"></rect>
                                <text x="40%" y="50%" fill="var(--bs-magic-secondary" dy=".3em">400x400</text>
                            </svg>
                        </div>
                    </div>

                    <!-- Modal -->
                    <div class="modal fade" id="moduleModal{{ module.id }}" tabindex="-1" aria-labelledby="moduleModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <div class="col">
                                        <h1 class="modal-title fs-5" id="moduleModalLabel">{{ module.name }}</h1>
                                        <div class="underline-highlight"></div>
                                    </div>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <small class="px-4 text-magic-secondary">
                                    Version {{ module.version }} vom {{ module.lastUpdated }}
                                </small>
                                <div class="modal-body">
                                    <ul>
                                        {% for item in module.description %}
                                            <li>
                                                {{ item.text }}
                                                {% if item.subtext %}
                                                    <ul>
                                                        {% for sub in item.subtext %}
                                                            <li> {{ sub }} </li>
                                                        {% endfor %}
                                                    </ul>
                                                {% endif %}
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                <hr class="text-magic-secondary">

                                <div class="modal-footer justify-content-end mx-4 row">
                                    <div class="col-4 col-sm-3 my-0">
                                        <button type="button" class="btn btn-magic-primary fw-light w-100" data-bs-dismiss="modal">
                                            <span class="align-middle">Download</span>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download ml-1" viewBox="0 0 16 16">
                                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                                                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
                                            </svg>
                                        </button>
                                    </div>
                                    <div class="col-3 col-sm-2 my-0">
                                        <button type="button" class="btn btn-magic-primary fw-light w-100" data-bs-dismiss="modal">
                                            <span class="align-middle">Close</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
                <hr class="my-md-5 my-3 text-magic-secondary">
            </div>
        </div>
    </div>
{% endif %}
